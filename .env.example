# Notion 集成令牌（发送到 Notion 时必填）。
NOTION_TOKEN=replace_me
# 生成页面所挂载的 Notion 父页面 ID。
NOTION_PARENT_PAGE_ID=300eee030a8080c180c1ea1e9a4c67e1
# Notion API 版本头。
NOTION_VERSION=2022-06-28
# Telegram Bot 令牌（发送到 Telegram 时必填）。
TELEGRAM_BOT_TOKEN=replace_me
# Telegram 目标聊天 ID。
TELEGRAM_CHAT_ID=replace_me
# 摘要模型提供方：bailian 或 gemini。
NEWS_OVERVIEW_SUMMARY_PROVIDER=bailian
# 摘要模型名（百炼推荐 glm-5）。
NEWS_OVERVIEW_SUMMARY_MODEL=glm-5
# 百炼 API Key（推荐，摘要与微信封面生图共用）。
BAILIAN_API_KEY=replace_me
# 百炼文本模型 OpenAI 兼容接口地址。
BAILIAN_TEXT_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# 百炼文本模型名（兜底）。
BAILIAN_TEXT_MODEL=glm-5
# 百炼文本请求连接超时（秒）。
BAILIAN_TEXT_CONNECT_TIMEOUT_SEC=20
# 百炼文本请求总超时（秒）。
BAILIAN_TEXT_MAX_TIME_SEC=120
# 百炼文本请求失败重试次数（不含首次请求）。
BAILIAN_TEXT_RETRIES=2
# 百炼文本重试基础等待毫秒（后续重试会线性递增）。
BAILIAN_TEXT_RETRY_DELAY_MS=1500
# 通用 HTTP 连接超时（秒）。
HTTP_CONNECT_TIMEOUT_SEC=15
# 通用 HTTP 请求总超时（秒）。
HTTP_MAX_TIME_SEC=90
# 兼容旧 Gemini 配置（当 NEWS_OVERVIEW_SUMMARY_PROVIDER=gemini 时使用）。
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3-flash
# 旧版摘要总长度上限；作为 TELEGRAM_MAX_CHARS 的兜底值。
BRIEF_MAX_CHARS=300
# 模型原始摘要文本的最大总字符数（拆分行前）。
SUMMARY_MAX_CHARS=900
# 摘要单行软长度上限；0 表示不限制单行长度。
SUMMARY_MAX_LINE_CHARS=0
# 发送到 Telegram 的消息最大字符数。
TELEGRAM_MAX_CHARS=300
# 标题聚类去重的相似度阈值。
DEDUPE_SIM_THRESHOLD=0.6
# 每个去重事件簇最多保留的标题数。
DEDUPE_MAX_PER_EVENT=2
# 为保证多样性，至少保留的单条簇数量。
DEDUPE_MIN_SINGLETONS=8
# 每个来源抓取并参与排序的 RSS 条目上限。
SOURCE_MAX_ITEMS=5
# 最终输出要求的最少摘要行数。
BRIEF_MIN_LINES=10
# 最终输出保留的最多摘要行数。
BRIEF_MAX_LINES=12
# 日期标签和提示词使用的时区。
TIME_ZONE=America/New_York
# 输出渠道：all / notion / telegram / wechat_official_account / json / render（支持逗号分隔）。
NEWS_OVERVIEW_CHANNELS=all
# 是否使用已有 JSON 快照而非实时抓取（1/0）。
NEWS_OVERVIEW_USE_JSON_SNAPSHOT=1
# 快照模式启用时读取的 JSON 路径。
NEWS_OVERVIEW_JSON_SNAPSHOT_PATH=news-overview.json
# 快照模式下“新鲜度告警”阈值（小时），超过即输出 warning 日志，不阻断流程。
NEWS_OVERVIEW_SNAPSHOT_MAX_AGE_HOURS=24
# 每日流水线：live 刷新阶段使用的渠道（建议仅 json,render）。
PIPELINE_REFRESH_CHANNELS=json,render
# 每日流水线：snapshot 发布阶段使用的渠道（publish=notion+telegram）。
PIPELINE_PUBLISH_CHANNELS=publish
# 每日流水线：是否追加微信公众号发送（1/0）。
PIPELINE_ENABLE_WECHAT=0
# 每日流水线锁文件路径（防止并发重复发送）。
PIPELINE_LOCK_FILE=/tmp/news-dashboard-pipeline.lock
# 是否使用 Azure Translator 将最终内容翻译为中文（1/0）。
NEWS_OVERVIEW_TRANSLATE_TO_ZH=0
# 是否启用敏感词覆盖过滤（1/0）。
NEWS_OVERVIEW_CONTENT_FILTER=0
# 敏感词替换掩码文本。
NEWS_OVERVIEW_CONTENT_FILTER_MASK=**
# 微信公众号 AppID（启用 wechat_official_account 渠道时必填）。
WECHAT_OFFICIAL_ACCOUNT_APP_ID=replace_me
# 微信公众号 AppSecret（启用 wechat_official_account 渠道时必填）。
WECHAT_OFFICIAL_ACCOUNT_APP_SECRET=replace_me
# 微信封面图由程序自动截图并上传素材库，不需要手填 media_id。
# 微信图文标题（留空则默认：简报速览）。
WECHAT_OFFICIAL_ACCOUNT_TITLE=
# 微信图文作者名。
WECHAT_OFFICIAL_ACCOUNT_AUTHOR=AI助手
# 微信图文摘要（留空则自动由速览行拼接生成）。
WECHAT_OFFICIAL_ACCOUNT_DIGEST=
# 图文是否显示封面图（1/0）。
WECHAT_OFFICIAL_ACCOUNT_SHOW_COVER_PIC=1
# 微信图文是否开启评论（1/0）。
WECHAT_OFFICIAL_ACCOUNT_NEED_OPEN_COMMENT=0
# 微信图文是否仅粉丝可评论（1/0）。
WECHAT_OFFICIAL_ACCOUNT_ONLY_FANS_CAN_COMMENT=0
# 微信封面是否优先使用模型生图（1=是，失败自动回退 Playwright 截图）。
WECHAT_COVER_USE_MODEL=1
# 微信封面生图模型接口（百炼官方异步任务接口）。
BAILIAN_IMAGE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/image-generation/generation
# qwen-image-plus 模型可选接口（多模态生成，同步返回）。
BAILIAN_MM_IMAGE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# 微信封面生图模型名。
BAILIAN_IMAGE_MODEL=qwen-image-plus-2026-01-09
# 微信封面生图尺寸（wan2.6-image 推荐 1280*1280）。
WECHAT_COVER_IMAGE_SIZE=1280*1280
# 微信封面生图提示词（可留空使用内置模板）。
WECHAT_COVER_IMAGE_PROMPT=
# 可选 HTTP 代理地址。
HTTP_PROXY=socks5h://127.0.0.1:1080
# 可选 HTTPS 代理地址（curl 请求也会使用）。
HTTPS_PROXY=socks5h://127.0.0.1:1080
# Azure Translator 订阅密钥（开启翻译时必填）。
AZURE_TRANSLATOR_KEY=replace_me
# Azure Translator 资源区域。
AZURE_TRANSLATOR_REGION=replace_me
# Azure Translator 接口地址。
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# 服务端触发 overview 脚本时使用的 Node 可执行文件路径。
NODE_BIN=/home/cori/.nvm/versions/node/v22.22.0/bin/node
# TheNewsAPI 的 Key（用于补充“其他新闻”）。
THENEWSAPI_KEY=replace_me
# TheNewsAPI 接口地址。
THENEWSAPI_ENDPOINT=https://api.thenewsapi.com/v1/news/top
# TheNewsAPI 请求语言。
THENEWSAPI_LANGUAGE=en
# TheNewsAPI 单次请求条目上限。
THENEWSAPI_LIMIT=10
# TheNewsAPI 分类列表（逗号分隔）。
THENEWSAPI_CATEGORIES=business,tech,politics
# 飞书开放平台 App ID（启用飞书 Bitable 新闻源时必填）。
FEISHU_APP_ID=replace_me
# 飞书开放平台 App Secret。
FEISHU_APP_SECRET=replace_me
# 飞书 Bitable Base ID。
FEISHU_BASE_ID=replace_me
# 飞书 Bitable Table ID。
FEISHU_TABLE_ID=replace_me
# 飞书 Source 字段筛选（逗号分隔；留空表示不过滤）。
FEISHU_SOURCE_FILTERS=
# 每个 Source 最多保留条数（服务端与消化层共用）。
FEISHU_PER_SOURCE_LIMIT=20
# 飞书扫描上限（防止超大表导致超时）。
FEISHU_MAX_SCAN=2000
# API 访问密钥（配置后将对 /api/* 启用鉴权；支持 X-API-Key / Bearer / ?api_key=）。
NEWS_API_KEY=replace_me
# 服务模式下是否自动刷新 news overview（1/0）。
NEWS_OVERVIEW_AUTO_REFRESH=0
# 自动刷新缓存的 TTL（分钟）。
NEWS_OVERVIEW_TTL_MIN=30
# 是否渲染并保存 HTML 产物（1/0）。
NEWS_OVERVIEW_RENDER_HTML=1
# 是否通过 Playwright 渲染并保存图片产物（1/0）。
NEWS_OVERVIEW_RENDER_IMAGE=0
# 渲染产物输出目录。
NEWS_OVERVIEW_RENDER_DIR=logs
# 图片格式：png 或 jpg。
NEWS_OVERVIEW_RENDER_FORMAT=png
# 渲染视口宽度（像素）。
NEWS_OVERVIEW_RENDER_WIDTH=1080
# 渲染设备缩放倍率。
NEWS_OVERVIEW_RENDER_SCALE=2
# 当格式为 jpg 时的 JPEG 质量。
NEWS_OVERVIEW_RENDER_QUALITY=88
# 渲染预设：wechat_official_account / xiaohongshu / xiaohongshu-square / 留空。
NEWS_OVERVIEW_RENDER_PROFILE=
# 是否将长图切分为多张图片（1/0）。
NEWS_OVERVIEW_RENDER_SPLIT=0
# 切分渲染时每段高度。
NEWS_OVERVIEW_RENDER_SEGMENT_HEIGHT=2200
# 切分段之间的重叠像素数。
NEWS_OVERVIEW_RENDER_SEGMENT_OVERLAP=80
# 是否从顶部区域生成方形封面图（1/0）。
NEWS_OVERVIEW_RENDER_COVER_SQUARE=0
# 是否生成小红书风格的顺序别名文件（1/0）。
NEWS_OVERVIEW_RENDER_XHS_ALIAS=0
